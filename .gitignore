# Runtime artifacts (regenerate on their own)
.local/
node_modules/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.tmp/
dist/

# Production artifacts — large binaries, don't commit
recordings/*.mp4
recordings/*.gif
recordings/*.mov
recordings/*.avi
# Cast files and docs ARE tracked (source of truth)
!recordings/*.cast
!recordings/*.md
!recordings/.gitkeep
!distribution/*.md
!distribution/.gitkeep

# Flight plans — ephemeral dispatch artifacts (durable record is commit trailer)
flight-plans/

# Claude Code harness artifacts (regenerated per session)
.claude.json
.claude/
mcp-needs-auth-cache.json

# Runtime state
var/
